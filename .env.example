# Copy to .env and fill in values. Never commit .env.

# 可选：日志级别 DEBUG | INFO | WARNING | ERROR（前后端共用 `paperpilot` 日志树）
# LOG_LEVEL=INFO

# 可选：日志目录（相对当前工作目录），后端写 backend.log，前端写 streamlit.log，滚动备份
# PAPERPILOT_LOG_DIR=logs

# 可选：同时把 paperpilot 日志打到终端（1 / true / yes / on）
# LOG_TO_CONSOLE=

# FastAPI base URL for Streamlit (default matches local uvicorn)
BACKEND_URL=http://127.0.0.1:8000

# OpenAI-compatible API key（使用千问时可填阿里云百炼 Key）
OPENAI_API_KEY=

# OpenAI-compatible base URL（千问兼容模式默认地址）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：qwen-turbo | qwen-plus | qwen-max 等（按账号可用模型填写）
# OPENAI_MODEL=qwen3.6-plus
