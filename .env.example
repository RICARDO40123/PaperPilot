# Copy to .env and fill in values. Never commit .env.

# FastAPI base URL for Streamlit (default matches local uvicorn)
BACKEND_URL=http://127.0.0.1:8000

# Alibaba DashScope API key for Qwen（精读建议 / 结构化意图必填）
DASHSCOPE_API_KEY=

# 可选：qwen-turbo | qwen-plus | qwen-max 等（按账号可用模型填写）
# QWEN_MODEL=qwen-turbo
