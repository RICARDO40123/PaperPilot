# Copy to .env and fill in values. Never commit .env.

# FastAPI base URL for Streamlit (default matches local uvicorn)
BACKEND_URL=http://127.0.0.1:8000

# OpenAI-compatible API key（使用千问时可填阿里云百炼 Key）
OPENAI_API_KEY=

# OpenAI-compatible base URL（千问兼容模式默认地址）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：qwen-turbo | qwen-plus | qwen-max 等（按账号可用模型填写）
# OPENAI_MODEL=qwen3.6-plus
